<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="local/courseheatmappro/db" VERSION="2026050408" COMMENT="XMLDB file for local_courseheatmappro"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../../lib/xmldb/xmldb.xsd"
>
  <TABLES>
    <TABLE NAME="local_courseheatmappro_exports" COMMENT="History of CSV exports generated by Course Engagement Map Pro">
