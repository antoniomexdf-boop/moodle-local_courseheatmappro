{{!
    @template local_courseheatmappro/summary_cards

    Executive summary cards for the dashboard.

    Context variables required for this template:
    * cards - Summary card rows

    Example context (json):
    {
        "cards": [
            {"label": "Engagement health", "value": "72% (Good)", "stateclass": "is-medium"},
            {"label": "Low engagement sections", "value": "2", "stateclass": "is-low"}
        ]
    }
}}
<div class="lchp-summarygrid">
    {{#cards}}
        <article class="lchp-card {{stateclass}}">
            <span class="lchp-card__label">{{label}}</span>
            <strong class="lchp-card__value">{{value}}</strong>
        </article>
    {{/cards}}
</div>
