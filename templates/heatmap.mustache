{{!
    @template local_courseheatmappro/heatmap

    Section and activity heatmap for the selected course.

    Context variables required for this template:
    * sectionheatmaplabel - Section heatmap heading
    * activityheatmaplabel - Activity heatmap heading
    * heatmapnote - Supporting note
    * hasactivities - Whether there are activities to display
    * sectionheatmap - Section summary rows
    * activityheatmap - Activity summary rows
    * legend - Legend rows
    * emptycoursemessage - Empty state message when no activities exist
    * nocompletiontrackingnote - Completion tracking note

    Example context (json):
    {
        "sectionheatmaplabel": "Section heatmap",
        "activityheatmaplabel": "Activity and resource heatmap",
        "heatmapnote": "Scores are derived from course access, completion, and grade signals within the selected period.",
        "hasactivities": true,
        "sectionheatmap": [
            {"stateclass": "is-medium", "name": "Section 1", "score": 72, "activitycountlabel": "4 activities", "trackablecountlabel": "3 trackable modules", "nocompletioncountlabel": "1 modules without completion tracking"}
        ],
        "activityheatmap": [
            {"stateclass": "is-high", "hidden": false, "hasactivityurl": true, "activityurl": "/mod/page/view.php?id=5", "name": "Page 1. Welcome reading.", "engagementavailable": true, "engagementpercentage": 85, "trackingstatus": "Completion tracking enabled", "sectionname": "Section 1", "moduletype": "Activity", "completiontracking": true, "completeduserslabel": "Completed users", "completioncount": 3, "notcompleteduserslabel": "Not completed users", "notcompletioncount": 1, "gradeavailable": true, "gradeuserslabel": "Graded users", "gradecount": 2, "notgradeduserslabel": "Not graded users", "notgradedcount": 2, "enrolledcount": 4, "engagementlevellabel": "Engagement level", "engagementlabel": "High engagement", "suggestedactionlabel": "Suggested action", "suggestedaction": "Keep this activity as a reference model for the course.", "viewcompletedstudentslabel": "View completed students", "viewnotcompletedstudentslabel": "View not completed students", "viewgradedstudentslabel": "View graded students", "viewnotgradedstudentslabel": "View not graded students"}
        ],
        "legend": [
            {"label": "High engagement", "stateclass": "is-high"}
        ],
        "emptycoursemessage": "This course does not contain visible modules for the selected view.",
        "nocompletiontrackingnote": "Modules without completion tracking are shown separately and are not treated as failures."
    }
}}
<details class="lchp-panel" open>
    <summary class="lchp-panel__summary">{{sectionheatmaplabel}}</summary>
    <p class="lchp-panel__note">{{heatmapnote}}</p>
    {{#hasactivities}}
        <div class="lchp-heatmapgrid">
            {{#sectionheatmap}}
                <article class="lchp-heatmapitem {{stateclass}}">
                    <div class="lchp-heatmapitem__head">
                        <h3 class="lchp-heatmapitem__title">{{name}}</h3>
                        <span class="lchp-heatmapitem__score">{{score}}%</span>
                    </div>
                    <p class="lchp-heatmapitem__meta">{{activitycountlabel}}</p>
                    <p class="lchp-heatmapitem__meta">{{trackablecountlabel}}</p>
                    <p class="lchp-heatmapitem__meta">{{nocompletioncountlabel}}</p>
                </article>
            {{/sectionheatmap}}
        </div>
    {{/hasactivities}}
    {{^hasactivities}}
        <p class="lchp-emptycard__text">{{emptycoursemessage}}</p>
    {{/hasactivities}}
</details>

<details class="lchp-panel" open>
    <summary class="lchp-panel__summary">{{activityheatmaplabel}}</summary>
    {{#hasactivities}}
        <div class="lchp-heatmapgrid">
            {{#activityheatmap}}
                <article class="lchp-heatmapitem {{stateclass}} {{#hidden}}is-hidden{{/hidden}}">
                    <div class="lchp-heatmapitem__head">
                        <h3 class="lchp-heatmapitem__title">
                            {{#hasactivityurl}}
                                <a class="lchp-modulelink" href="{{activityurl}}">{{name}}</a>
                            {{/hasactivityurl}}
                            {{^hasactivityurl}}
                                <span class="lchp-modulelink lchp-modulelink--plain">{{name}}</span>
                            {{/hasactivityurl}}
                        </h3>
                        <span class="lchp-heatmapitem__score">
                            {{#engagementavailable}}
                                {{engagementpercentage}}%
                            {{/engagementavailable}}
                            {{^engagementavailable}}
                                {{trackingstatus}}
                            {{/engagementavailable}}
                        </span>
                    </div>
                    <p class="lchp-heatmapitem__meta">{{sectionname}}</p>
                    <p class="lchp-heatmapitem__meta">{{moduletype}} · {{trackingstatus}}</p>
                    {{#completiontracking}}
                        <p class="lchp-heatmapitem__meta">
                            <button type="button"
                                class="lchp-countbutton js-lchp-open-students"
                                data-courseid="{{courseid}}"
                                data-cmid="{{cmid}}"
                                data-listtype="completed"
                                aria-label="{{viewcompletedstudentslabel}}"
                                title="{{viewcompletedstudentslabel}}">
                                {{completeduserslabel}}
                            </button>
                            <span class="lchp-countvalue">{{completioncount}}</span>
                            <span class="lchp-countmeta">/ {{enrolledcount}}</span>
                        </p>
                        <p class="lchp-heatmapitem__meta">
                            <button type="button"
                                class="lchp-countbutton js-lchp-open-students"
                                data-courseid="{{courseid}}"
                                data-cmid="{{cmid}}"
                                data-listtype="notcompleted"
                                aria-label="{{viewnotcompletedstudentslabel}}"
                                title="{{viewnotcompletedstudentslabel}}">
                                {{notcompleteduserslabel}}
                            </button>
                            <span class="lchp-countvalue">{{notcompletioncount}}</span>
                            <span class="lchp-countmeta">/ {{enrolledcount}}</span>
                        </p>
                    {{/completiontracking}}
                    {{#gradeavailable}}
                        <p class="lchp-heatmapitem__meta">
                            <button type="button"
                                class="lchp-countbutton js-lchp-open-students"
                                data-courseid="{{courseid}}"
                                data-cmid="{{cmid}}"
                                data-listtype="graded"
                                aria-label="{{viewgradedstudentslabel}}"
                                title="{{viewgradedstudentslabel}}">
                                {{gradeuserslabel}}
                            </button>
                            <span class="lchp-countvalue">{{gradecount}}</span>
                            <span class="lchp-countmeta">/ {{enrolledcount}}</span>
                        </p>
                        <p class="lchp-heatmapitem__meta">
                            <button type="button"
                                class="lchp-countbutton js-lchp-open-students"
                                data-courseid="{{courseid}}"
                                data-cmid="{{cmid}}"
                                data-listtype="notgraded"
                                aria-label="{{viewnotgradedstudentslabel}}"
                                title="{{viewnotgradedstudentslabel}}">
                                {{notgradeduserslabel}}
                            </button>
                            <span class="lchp-countvalue">{{notgradedcount}}</span>
                            <span class="lchp-countmeta">/ {{enrolledcount}}</span>
                        </p>
                    {{/gradeavailable}}
                    <p class="lchp-heatmapitem__meta">{{engagementlevellabel}}: {{engagementlabel}}</p>
                    <div class="lchp-heatmapitem__action">
                        <span class="lchp-heatmapitem__actionlabel">{{suggestedactionlabel}}</span>
                        <p class="lchp-heatmapitem__actiontext">{{suggestedaction}}</p>
                    </div>
                </article>
            {{/activityheatmap}}
        </div>
    {{/hasactivities}}
    {{^hasactivities}}
        <p class="lchp-emptycard__text">{{emptycoursemessage}}</p>
    {{/hasactivities}}
</details>

<details class="lchp-panel">
    <summary class="lchp-panel__summary">{{heatmaplegendlabel}}</summary>
    <ul class="lchp-legend">
        {{#legend}}
            <li class="lchp-legend__item {{stateclass}}">
                <span class="lchp-legend__swatch"></span>
                <span class="lchp-legend__label">{{label}}</span>
            </li>
        {{/legend}}
    </ul>
    <p class="lchp-panel__note">{{nocompletiontrackingnote}}</p>
</details>
