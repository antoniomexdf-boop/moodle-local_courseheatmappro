{{!
    @template local_courseheatmappro/history

    Export history table for the selected course.

    Context variables required for this template:
    * exporthistorylabel - Export history heading
    * hasexporthistory - Whether export rows exist
    * exporthistory - Export history rows
    * emptyhistorymessage - Empty state message
    * downloadunavailablemessage - Download unavailable note
    * downloadlabel - Download action label
    * exporttimelabel - Time column label
    * courselabel - Course column label
    * exporttypelabel - Export type column label
    * filenamelabel - Filename column label
    * exportedbylabel - Exported by column label

    Example context (json):
    {
        "exporthistorylabel": "Export history",
        "hasexporthistory": true,
        "downloadlabel": "Download",
        "exporttimelabel": "Export time",
        "courselabel": "Course",
        "exporttypelabel": "Export type",
        "filenamelabel": "Filename",
        "exportedbylabel": "Exported by",
        "downloadunavailablemessage": "This export can no longer be regenerated.",
        "exporthistory": [
            {"timecreated": "2026-05-04 12:00", "coursefullname": "Demo course", "exporttype": "CSV", "filename": "course-heatmap-2.csv", "exportedby": "Antonio", "downloadurl": "/local/courseheatmappro/download.php?historyid=1&sesskey=abc"}
        ],
        "emptyhistorymessage": "No exports have been generated for this course yet."
    }
}}
<details class="lchp-panel" open>
    <summary class="lchp-panel__summary">{{exporthistorylabel}}</summary>
    {{#hasexporthistory}}
        <div class="table-responsive">
            <table class="generaltable lchp-historytable">
                <thead>
                    <tr>
                        <th scope="col">{{exporttimelabel}}</th>
                        <th scope="col">{{courselabel}}</th>
                        <th scope="col">{{exporttypelabel}}</th>
                        <th scope="col">{{filenamelabel}}</th>
                        <th scope="col">{{exportedbylabel}}</th>
                        <th scope="col">{{downloadlabel}}</th>
                    </tr>
                </thead>
                <tbody>
                    {{#exporthistory}}
                        <tr>
                            <td>{{timecreated}}</td>
                            <td>{{coursefullname}}</td>
                            <td>{{exporttype}}</td>
                            <td>{{filename}}</td>
                            <td>{{exportedby}}</td>
                            <td>
                                {{#downloadurl}}
                                    <a class="btn btn-sm btn-secondary" href="{{downloadurl}}">{{downloadlabel}}</a>
                                {{/downloadurl}}
                                {{^downloadurl}}
                                    <span class="lchp-inlinehint">{{downloadunavailablemessage}}</span>
                                {{/downloadurl}}
                            </td>
                        </tr>
                    {{/exporthistory}}
                </tbody>
            </table>
        </div>
    {{/hasexporthistory}}
    {{^hasexporthistory}}
        <p class="lchp-emptycard__text">{{emptyhistorymessage}}</p>
    {{/hasexporthistory}}
</details>
