{{!
    @template local_courseheatmappro/student_list_modal

    Modal table of students for completed, not completed, graded, and not graded lists.

    Context variables required for this template:
    * title - Modal title
    * coursefullname - Course name
    * activityname - Activity name
    * courselabel - Course field label
    * activitylabel - Activity field label
    * studentnamelabel - Student name label
    * studentemaillabel - Email label
    * completionstatuslabel - Completion status label
    * statuslabel - Generic status label
    * completiondatelabel - Completion date label
    * gradelabel - Grade label
    * emptymessage - Empty state message
    * showemail - Whether to display email
    * showcompletiondate - Whether to display completion date
    * showgrade - Whether to display grades
    * showstatus - Whether to display status
    * hasstudents - Whether any students exist
    * students - Student rows

    Example context (json):
    {
        "title": "Completed students",
        "coursefullname": "Demo course",
        "activityname": "Page 1. Welcome reading.",
        "courselabel": "Course",
        "activitylabel": "Activity title",
        "studentnamelabel": "Student name",
        "studentemaillabel": "Email",
        "completionstatuslabel": "Completion status",
        "statuslabel": "Status",
        "completiondatelabel": "Completion date",
        "gradelabel": "Grade",
        "emptymessage": "No students found for this activity.",
        "showemail": true,
        "showcompletiondate": true,
        "showgrade": false,
        "showstatus": false,
        "hasstudents": true,
        "students": [
            {"fullname": "Alice Smith", "email": "alice@example.com", "completionstatus": "Completed", "status": "", "completiondate": "2026-05-04 12:30", "grade": ""}
        ]
    }
}}
<div class="lchp-modal">
    <p class="lchp-modal__meta"><strong>{{courselabel}}:</strong> {{coursefullname}}</p>
    <p class="lchp-modal__meta"><strong>{{activitylabel}}:</strong> {{activityname}}</p>

    {{#hasstudents}}
        <div class="table-responsive">
            <table class="generaltable lchp-modaltable">
                <thead>
                    <tr>
                        <th scope="col">{{studentnamelabel}}</th>
                        {{#showemail}}
                            <th scope="col">{{studentemaillabel}}</th>
                        {{/showemail}}
                        {{#showcompletiondate}}
                            <th scope="col">{{completionstatuslabel}}</th>
                            <th scope="col">{{completiondatelabel}}</th>
                        {{/showcompletiondate}}
                        {{#showgrade}}
                            <th scope="col">{{gradelabel}}</th>
                        {{/showgrade}}
                        {{#showstatus}}
                            <th scope="col">{{statuslabel}}</th>
                        {{/showstatus}}
                    </tr>
                </thead>
                <tbody>
                    {{#students}}
                        <tr>
                            <td>{{fullname}}</td>
                            {{#showemail}}
                                <td>{{email}}</td>
                            {{/showemail}}
                            {{#showcompletiondate}}
                                <td>{{completionstatus}}</td>
                                <td>{{completiondate}}</td>
                            {{/showcompletiondate}}
                            {{#showgrade}}
                                <td>{{grade}}</td>
                            {{/showgrade}}
                            {{#showstatus}}
                                <td>{{status}}</td>
                            {{/showstatus}}
                        </tr>
                    {{/students}}
                </tbody>
            </table>
        </div>
    {{/hasstudents}}

    {{^hasstudents}}
        <p class="lchp-modal__empty">{{emptymessage}}</p>
    {{/hasstudents}}
</div>
