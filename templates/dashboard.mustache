{{!
    @template local_courseheatmappro/dashboard

    Dashboard shell for the Course Engagement Map Pro landing page.

    Context variables required for this template:
    * title - Dashboard title
    * subtitle - Dashboard subtitle
    * formaction - Form action URL
    * selectcourselabel - Course selector label
    * choosecourselabel - Default course selector option
    * selectperiodlabel - Period selector label
    * chooseperiodlabel - Default period selector option
    * viewheatmaplabel - Submit button label
    * exportcsvlabel - Export button label
    * hascourse - Whether a course has been selected
    * courseoptions - Available course selector options
    * periodoptions - Available period selector options
    * coursefullname - Selected course name
    * periodlabel - Selected period label
    * executivesummarylabel - Summary heading
    * summaryhtml - Rendered summary cards HTML
    * distributionhtml - Rendered distribution HTML
    * heatmaphtml - Rendered heatmap HTML
    * historyhtml - Rendered history HTML
    * pluginnamelabel - Plugin title for the empty state
    * emptymessage - Empty state message
    * canexport - Whether export is available
    * exporturl - CSV export URL

    Example context (json):
    {
        "title": "Course Engagement Map Pro",
        "subtitle": "Understand where students engage, struggle, and drop off in your course.",
        "formaction": "/local/courseheatmappro/index.php",
        "selectcourselabel": "Select course",
        "choosecourselabel": "Choose a course",
        "selectperiodlabel": "Select period",
        "chooseperiodlabel": "Choose a period",
        "viewheatmaplabel": "View heatmap",
        "exportcsvlabel": "Export CSV",
        "hascourse": true,
        "courseoptions": [
            {"value": 2, "label": "Demo course", "selected": true}
        ],
        "periodoptions": [
            {"value": "30d", "label": "Last 30 days", "selected": true}
        ],
        "coursefullname": "Demo course",
        "periodlabel": "Last 30 days",
        "executivesummarylabel": "Executive summary",
        "summaryhtml": "Summary HTML",
        "distributionhtml": "Distribution HTML",
        "heatmaphtml": "Heatmap HTML",
        "historyhtml": "History HTML",
        "pluginnamelabel": "Course Engagement Map Pro",
        "emptymessage": "Select a course to view its engagement heatmap.",
        "canexport": true,
        "exporturl": "/local/courseheatmappro/export.php?courseid=2&sesskey=abc"
    }
}}
<div class="lchp-shell">
    <section class="lchp-hero">
        <div class="lchp-hero__content">
            <h1 class="lchp-title">{{title}}</h1>
            <p class="lchp-subtitle">{{subtitle}}</p>
            {{#hascourse}}
                <p class="lchp-meta">{{coursefullname}} · {{periodlabel}}</p>
            {{/hascourse}}
        </div>
        <form class="lchp-hero__controls" action="{{formaction}}" method="get">
            <div class="lchp-control">
                <label for="lchp-courseid" class="lchp-label">{{selectcourselabel}}</label>
                <select id="lchp-courseid" name="courseid" class="custom-select">
                    <option value="0" label="{{choosecourselabel}}">{{choosecourselabel}}</option>
                    {{#courseoptions}}
                        <option value="{{value}}" {{#selected}}selected="selected"{{/selected}}>{{label}}</option>
                    {{/courseoptions}}
                </select>
            </div>
            <div class="lchp-control">
                <label for="lchp-period" class="lchp-label">{{selectperiodlabel}}</label>
                <select id="lchp-period" name="period" class="custom-select">
                    {{#periodoptions}}
                        <option value="{{value}}" {{#selected}}selected="selected"{{/selected}}>{{label}}</option>
                    {{/periodoptions}}
                </select>
            </div>
            <div class="lchp-control lchp-control--actions">
                <button type="submit" class="btn btn-primary">{{viewheatmaplabel}}</button>
                {{#canexport}}
                    {{#hascourse}}
                        <a class="btn btn-secondary lchp-export" href="{{exporturl}}">{{exportcsvlabel}}</a>
                    {{/hascourse}}
                {{/canexport}}
            </div>
        </form>
    </section>

    {{#hascourse}}
        <section class="lchp-summary">
            <h2 class="lchp-sectiontitle">{{executivesummarylabel}}</h2>
            {{{summaryhtml}}}
        </section>

        <section class="lchp-chart">
            {{{distributionhtml}}}
        </section>

        <section class="lchp-heatmap">
            {{{heatmaphtml}}}
        </section>

        {{#canexport}}
            <section class="lchp-history">
                {{{historyhtml}}}
            </section>
        {{/canexport}}
    {{/hascourse}}

    {{^hascourse}}
        <section class="lchp-emptycard">
            <h2 class="lchp-sectiontitle">{{pluginnamelabel}}</h2>
            <p class="lchp-emptycard__text">{{emptymessage}}</p>
        </section>
    {{/hascourse}}
</div>
