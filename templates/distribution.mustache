{{!
    @template local_courseheatmappro/distribution

    Engagement distribution summary for the selected course.

    Context variables required for this template:
    * engagementdistributionlabel - Distribution heading
    * distributionhelplabel - Supporting helper text
    * distributionchart - Chart data with segments

    Example context (json):
    {
        "engagementdistributionlabel": "Engagement distribution",
        "distributionhelplabel": "This distribution summarizes module health across the selected course.",
        "distributionchart": {
            "segments": [
                {"label": "High engagement", "count": 4, "percent": 40, "stateclass": "is-high"},
                {"label": "Medium engagement", "count": 3, "percent": 30, "stateclass": "is-medium"},
                {"label": "Low engagement", "count": 2, "percent": 20, "stateclass": "is-low"},
                {"label": "No activity", "count": 1, "percent": 10, "stateclass": "is-none"}
            ]
        }
    }
}}
<details class="lchp-panel" open>
    <summary class="lchp-panel__summary">{{engagementdistributionlabel}}</summary>
    <p class="lchp-panel__note">{{distributionhelplabel}}</p>
    <div class="lchp-distribution">
        <div class="lchp-distribution__bar" role="img" aria-label="{{engagementdistributionlabel}}">
            {{#distributionchart.segments}}
                <span class="lchp-distribution__segment {{stateclass}}" style="width: {{percent}}%;" title="{{label}}: {{count}}"></span>
            {{/distributionchart.segments}}
        </div>
        <div class="lchp-distribution__grid">
            {{#distributionchart.segments}}
                <article class="lchp-distribution__card {{stateclass}}">
                    <span class="lchp-distribution__label">{{label}}</span>
                    <strong class="lchp-distribution__value">{{count}}</strong>
                    <span class="lchp-distribution__meta">{{percent}}%</span>
                </article>
            {{/distributionchart.segments}}
        </div>
    </div>
</details>
